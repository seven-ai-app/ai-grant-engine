# AI Grant Engine - LLM Provider Configuration
# Fill in the API keys for providers you want to use.
# At least ONE provider key is required.

# === FREE PROVIDERS ===
GROQ_API_KEY=
GEMINI_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=

# === PAID PROVIDERS ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=

# === PROVIDER PREFERENCES ===
# Comma-separated priority order. System uses first available.
# Options: claude, openai, gemini, groq, together, openrouter, mistral
LLM_PRIORITY_HEBREW=claude,openai,gemini,groq,together,openrouter,mistral
LLM_PRIORITY_STRUCTURED=gemini,groq,together,openrouter,claude,openai,mistral
LLM_PRIORITY_REASONING=claude,openai,gemini,groq,mistral,together,openrouter

# === OPTIONAL INTEGRATIONS ===
GITHUB_TOKEN=
# ChromaDB path (default: ./chroma_db)
CHROMA_DB_PATH=./chroma_db

# === OUTPUT ===
OUTPUT_DIR=./output
